# 実際のFirebaseプロジェクト作成は後回しにしている（未設定時はEmulator用ダミー値にフォールバックする）。
# 用意でき次第、Firebaseコンソールのプロジェクト設定からコピーする。
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ローカル開発でFirestore Emulatorに接続する場合はtrueにする
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true

# サーバ側（/api/cron/fetch-weather、Vercel Cron Jobs）専用。Firestore Emulator接続時は不要。
# Firebaseコンソール > プロジェクトの設定 > サービスアカウント > 新しい秘密鍵の生成 で取得する。
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# /api/cron/fetch-weather を外部から不正に叩かれないようにする共有シークレット（任意の文字列）。
# VercelのCron Jobsはこのシークレットを自動でAuthorizationヘッダに付与する。
CRON_SECRET=
